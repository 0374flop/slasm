;+./jslib.js:js+;

(clog "=== нативный JS модуль ===")

(clog (upper "hello world"))
(clog (lower "SLASM IS COOL"))
(clog (strlen "test"))

(clog (trim "   пробелы   "))
(clog (includes "hello world" "world"))
(clog (replace "foo bar foo" "foo" "baz"))

(clog "=== математика ===")

(clog (pow 2 10))
(clog (sqrt 144))
(clog (floor 3.7))
(clog (ceil 3.2))
(clog (round 3.5))

(clog "=== время ===")

(clog (now))
(clog (timestamp))

(clog "=== комбинируем ===")

(clog (upper (replace "hello slasm" "slasm" "world")))
(clog (floor (sqrt (pow 2 20))))
