(W 1 (?* 1 100))
(clog "Guess a number from 1 to 100!")
;-main-;
(clog "Enter your guess:")
(W 2 (q))
(? (= (R 1) (R 2)) (gln win))
(? (< (R 2) (R 1)) (gln low))
(? (> (R 2) (R 1)) (gln high))
;-win-;
(clog "You got it!")
(clog (R 1))
(jump (gln end))
;-low-;
(clog "Too low! Try higher.")
(jump (gln main))
;-high-;
(clog "Too high! Try lower.")
(jump (gln main))
;-end-;
(clog "Game over!")