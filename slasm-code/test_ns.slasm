;+./jslib.js:js+;
;+./stdlib:std+;

(clog "=== явные пространства имён ===")

(clog (js.upper "hello world"))
(clog (js.lower "SLASM IS COOL"))
(clog (js.pow 2 10))
(clog (js.sqrt 144))

(clog (std.double 7))
(clog (std.square 5))

(clog "=== комбинируем ===")

(clog (js.upper (std.double 3)))
(clog (js.floor (js.sqrt (js.pow 2 20))))
